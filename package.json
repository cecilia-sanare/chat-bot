{
  "name": "flarie",
  "version": "1.0.0",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "private": true,
  "scripts": {
    "dev": "bun run --cwd packages/demo dev",
    "start": "bun run --cwd packages/demo start",
    "build": "bun run --filter '!demo' 'build'",
    "types": "bun run --filter '!demo' 'types'"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "!packages/demo/**"
    ]
  },
  "dependencies": {
    "@ribbon-studios/logger": "^3.1.0"
  }
}
