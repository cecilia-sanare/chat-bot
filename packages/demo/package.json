    "@flarie/fluxer": "workspace:^",
    "@libsql/client": "^0.17.0",
    "@ribbon-studios/js-utils": "^3.0.1",
    "chalk": "^5.6.2",
    "dedent": "^1.7.1",
    "drizzle-orm": "^0.45.1",
